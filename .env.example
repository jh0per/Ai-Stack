# Ollama
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=ua-tech

# MCP storage server
MCP_HOST=127.0.0.1
MCP_PORT=3600
MCP_URL=http://127.0.0.1:3600/mcp

# Agent gateway
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=3700

# Optional filesystem/storage binaries. Leave defaults if installed there.
ZPOOL_BIN=/usr/sbin/zpool
ZFS_BIN=/usr/sbin/zfs
LSBLK_BIN=/usr/bin/lsblk
FINDMNT_BIN=/usr/bin/findmnt
SMARTCTL_BIN=/usr/sbin/smartctl
SMARTCTL_USE_SUDO=0
DOCKER_BIN=/usr/bin/docker
SYSTEMCTL_BIN=/usr/bin/systemctl

# File tools safety. Keep this narrow on shared systems.
FS_ALLOWED_ROOTS=/mnt
MAX_READ_FILE_BYTES=20000

# Allowed MCP tools for the gateway.
MCP_ALLOWED_TOOLS=zpool_list,zpool_status,zpool_status_x,zfs_list,disk_free,block_devices_json,disk_identity_json,disk_health_attributes_json,storage_usage_json,node_storage_usage_json,smart_devices_json,docker_containers_json,system_services,list_allowed_dir,read_text_file

# Optional web search through local SearXNG.
WEB_SEARCH_ENABLED=0
SEARXNG_URL=http://127.0.0.1:8888/search
WEB_MAX_RESULTS=8
SMART_WEB_DEFAULT=0
WEB_FETCH_TOP_N=3
WEB_FETCH_MAX_CHARS_PER_PAGE=7000

# Sia/Storj rented storage is expected to be highly used.
# Set NODE_STORAGE_CRIT_CAP=0 to disable critical alerts for allocation fullness.
NODE_STORAGE_WARN_CAP=95
NODE_STORAGE_CRIT_CAP=0

DEFAULT_TIMEZONE=UTC
LANGUAGE=uk
WEB_TRUSTED_DOMAINS=documentation.ubuntu.com,discourse.ubuntu.com,canonical.com,ubuntu.com,openzfs.github.io,github.com,docs.docker.com,docs.python.org,kernel.org,man7.org
