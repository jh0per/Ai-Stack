BOT_TOKEN=replace_me
ALLOWED_CHAT_ID=replace_me

TIMEZONE=UTC
LANGUAGE=uk

ALERT_ENABLED=1
ALERT_INTERVAL_MINUTES=60
ALERT_ONLY_ON_CHANGE=1
ALERT_UNCHANGED_COOLDOWN_HOURS=6

DAILY_SUMMARY_ENABLED=1
DAILY_TIME=09:00

AI_ENABLED=0
OLLAMA_URL=http://127.0.0.1:11434/api/chat
OLLAMA_MODEL=ua-tech

# Used by the legacy ZFS-specific Telegram commands.
ZPOOL_BIN=/usr/sbin/zpool
ZFS_BIN=/usr/sbin/zfs
STORAGE_STATUS_URL=http://127.0.0.1:3700/storage/status
WARN_POOL_CAP=80
CRIT_POOL_CAP=90
MIN_POOL_FREE_GB=500
WARN_DATASET_CAP=90
